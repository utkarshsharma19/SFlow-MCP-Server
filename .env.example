DATABASE_URL=postgresql+asyncpg://flowmind:flowmind_dev@localhost/flowmind
REDIS_URL=redis://localhost:6379
SFLOW_RT_URL=http://localhost:8008
TELEMETRY_API_URL=http://localhost:8080

# Multi-tenant auth (PR 20+): API keys are looked up in the api_keys table
# by sha256 hash. Migration 0003 seeds a default tenant and a development
# key ("dev-insecure-key") — rotate this immediately outside of dev.
# To issue new keys:
#   python -m scripts.seed create-tenant --slug acme --name "Acme"
#   python -m scripts.seed create-key  --tenant-slug acme --role analyst --name alice
TELEMETRY_API_KEY=dev-insecure-key

# gNMI / OpenConfig collector (PR 21).
# Comma-separated list of host[:port] entries. Default port is 6030 (Arista) —
# SONiC commonly uses 8080 over TLS. Leave unset to disable gNMI collection;
# the loop will idle but will not error.
#   GNMI_TARGETS=spine1:6030,leaf1:6030,leaf2:6030
GNMI_TARGETS=
GNMI_USERNAME=admin
GNMI_PASSWORD=
GNMI_POLL_INTERVAL_SECONDS=60

# Per-source → tenant routing cache TTL (PR 22). The ingest loops look up
# every (source_kind, source_identifier) → tenant_id mapping through a
# cached TenantRouter; this controls how often the cache is refreshed
# from the collector_sources table. Operators add mappings via:
#   python -m scripts.seed map-source --kind sflow --identifier 10.0.1.5 \
#       --tenant-slug acme
TENANT_ROUTING_TTL_SECONDS=60

LOG_LEVEL=INFO
